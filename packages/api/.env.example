# Database (Railway provides this automatically)
DATABASE_URL=postgresql://user:pass@host:5432/pulse

# Redis (Railway provides this automatically)
REDIS_URL=redis://host:6379

# API server
API_PORT=3001

# Auth: Clerk (get keys from https://dashboard.clerk.com)
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# Legacy agent API key (used before org-scoped keys)
AGENT_API_KEY=change-me-in-production

# JWT secret for internal tokens
JWT_SECRET=change-me-in-production

# Dev only: bypass Clerk auth (NEVER set in production)
# DEV_BYPASS_AUTH=true
